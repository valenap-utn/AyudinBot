// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}
// -------------------- CONFIG SERVERS --------------------
model GuildConfig {
  id                 String   @id @default(cuid())
  guildId            String   @unique
  adminRoleId        String?
  materialsChannelId String?
  questionsChannelId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  knowledgeSources   KnowledgeSource[]
}

// -------------------- ARCHIVOS --------------------
// Document => KnowledgeSource
model KnowledgeSource {
  id                  String   @id @default(cuid())
  guildId             String
  guild               GuildConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  title               String
  storageKey          String?   // id interno
  filePath            String?
  extractedText       String?

  sourceType          KnowledgeSourceType
  reliability         SourceReliability     @default(MEDIUM)
  priority            Int                   @default(100)
  isActive            Boolean               @default(true) //permite desactivar sin borrar

  externalSourceKey   String?
  metadataJson        String?

  questionCategory    QuestionCategory?

  uploadedByUserId    String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([guildId])
  @@index([guildId, sourceType])
  @@index([guildId, isActive])
  @@index([guildId, sourceType, isActive])
  @@index([guildId, sourceType, questionCategory])

  @@unique([guildId, externalSourceKey])
}

enum KnowledgeSourceType {
  PDF
  URL
  TEXT
  GITHUB_ISSUES
}

enum QuestionCategory{
  TP
  ADMINISTRATIVA
  TEORIA
}

enum SourceReliability {
  LOW
  MEDIUM
  HIGH
}

// -------------------- FAQs --------------------

enum FaqType {
  FECHAS_PARCIALES
  FECHAS_CHECKPOINT
  LINKS_IMPORTANTES
  INFO_TP
  CUSTOM
}

model Faq {
  id          String  @id @default(cuid())
  guildId     String
  tipo        FaqType
  titulo      String
  contenido   String
  dataJson    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([guildId])
  @@index([guildId, tipo])
}

// -------------------- LOGS --------------------

model SearchLog {
  id                String  @id @default(cuid())
  guildId           String
  query             String
  questionCategory  QuestionCategory?
  resultsReturned   Int
  totalMatches      Int
  createdAt         DateTime @default(now())

  @@index([guildId])
  @@index([createdAt])
}
